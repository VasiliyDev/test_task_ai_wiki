# Скопируйте в .env и заполните. .env в .gitignore — ключи не коммитим.
#
# ВАЖНО про режимы (подробно в README → «Два режима запуска»):
#   • Локально `npm run dev`  → генерит локальный claude (подписка), ключ НЕ нужен.
#   • В Docker (compose)      → claude внутрь контейнера не входит, нужен ANTHROPIC_API_KEY.

# --- Режим генерации ---
# Авто-выбор: если ANTHROPIC_API_KEY задан → ходим по API (провайдер anthropic).
# Если ключа нет → fallback на локальный Claude CLI («крутящийся» Claude на этой машине).
# Можно зафиксировать явно:
# LLM_PROVIDER=anthropic        # или claude-cli

# Ключ Anthropic для генерации по API (нужен для провайдера anthropic).
ANTHROPIC_API_KEY=sk-ant-api03-...

# Модель генерации (по умолчанию claude-opus-4-8 для anthropic).
LLM_MODEL=claude-opus-4-8

# Команда локального Claude CLI для режима claude-cli (промт идёт в stdin).
# LLM_CLI_CMD=claude -p --output-format text

# --- БД ---
# Путь к файловой БД (SQLite). Необязательно — по умолчанию data/aiwiki.sqlite.
# В docker-compose уже задан /app/data/aiwiki.sqlite (монтируется ./data).
# DB_FILE=data/aiwiki.sqlite
